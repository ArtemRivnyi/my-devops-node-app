{
  "name": "node-devops-boilerplate",
  "version": "1.0.0",
  "description": "Production-ready Node.js web server boilerplate with Docker, CI/CD, and Ansible deployment.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles --forceExit --coverage",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles --forceExit --ci --coverage"
  },
  "keywords": [
    "node.js",
    "express",
    "devops",
    "docker",
    "boilerplate"
  ],
  "author": "Artem Rivnyi",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^2.2.0",
    "express": "^5.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "transform": {},
    "testMatch": [
      "**/test/**/*.test.js"
    ]
  }
}